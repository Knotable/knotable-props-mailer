<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kmail</title>
  </head>
  <body style="font-family: Arial, Helvetica, sans-serif; font-size: 16px">
    <div style="text-align: center; max-width: 600px; margin: 0 auto">
      <div style="margin: 60px 0 40px; text-align: center">
        <img
          height="32"
          src="data:image/png;base64,"
        />
      </div>

      <div style="background: rgb(239, 235, 226); padding: 20px">
        <div style="font-size: 32px; margin: 20px 0">KMAIL</div>
        <h4>Here is your one-time login link to access your Kmail account</h4>

        <div style="padding: 20px">
          <a
            href="{{loginUrl}}"
            style="
              padding: 20px;
              /* background-color: rgb(4, 53, 50); */
              background-image: linear-gradient(176deg, #cca253, #b0893e);
              color: white;
            "
          >
            LOG ME IN
          </a>
        </div>

        <p style="color: #999; margin-top: 40px">
          If you did not send this request, please ignore this email.
        </p>
      </div>

      <footer style="padding: 20">
        <p>
          <img
            width="30"
            src="data:image/png;base64,"
          />
        </p>
        <p>© Kmail 2023. All rights reserved</p>
      </footer>
    </div>
  </body>
</html>
