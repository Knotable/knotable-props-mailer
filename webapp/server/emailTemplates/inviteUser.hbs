<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kmail</title>
  </head>
  <body style="font-family: Arial, Helvetica, sans-serif; font-size: 16px">
    <div style="text-align: center; max-width: 600px; margin: 0 auto">
      <div style="margin: 60px 0 40px; text-align: center">
        <img
          height="32"
          src="data:image/png;base64,"
        />
      </div>

      <div style="background: rgb(239, 235, 226); padding: 20px">
        <div style="font-size: 32px; margin: 20px 0">WELCOME TO KMAIL</div>
        <h4>Let's Take Your Marketing to New Heights.</h4>

        <div>
          <img
            src="https://d1wubs3nxxxkxo.cloudfront.net/uploads/2023-06/hZPBe7w4zwkC55EWo_liam-truong-oeDH20DVb2A-unsplash.jpg"
            style="width: 100%; opacity: 0.9"
          />
        </div>

        <p style="margin: 40px 0; line-height: 1.5em; padding: 0 2em">
          You have been exclusively invited to join Kmail, the ultimate platform
          for revolutionizing your marketing campaigns. We can't wait to have
          you on board and help you achieve unprecedented success.
        </p>

        <div style="padding: 20px">
          <a
            href="{{loginUrl}}"
            style="
              padding: 20px;
              background-image: linear-gradient(176deg, #cca253, #b0893e);
              color: white;
            "
          >
            ACCEPT INVITATION
          </a>
        </div>

        <div style="margin: 60px 0 40px">
          <div style="font-size: 32px; margin: 20px 0">WHAT'S NEXT</div>
        </div>

        <div style="text-align: left; background: #f4f1ea; padding: 0 20px">
          <table style="border-spacing: 0 30px">
            <thead>
              <tr style="vertical-align: top">
                <th width="60"></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr style="vertical-align: top">
                <td>
                  <img
                    width="24"
                    src="data:image/png;base64,"
                  />
                </td>
                <td>
                  <div style="font-weight: 600">SET UP YOUR ACCOUNT</div>
                  <p>
                    Complete your profile by adding essential information, such
                    as your first name, last name and photo.
                  </p>
                </td>
              </tr>
              <tr style="vertical-align: top">
                <td>
                  <img
                    width="24"
                    src="data:image/png;base64,"
                  />
                </td>
                <td>
                  <div style="font-weight: 600">COMPOSE YOUR FIRST EMAIL</div>
                  <p>
                    Personalize content, add visuals, and compose a compelling
                    subject line.
                  </p>
                </td>
              </tr>
              <tr style="vertical-align: top">
                <td>
                  <img
                    width="24"
                    src="data:image/png;base64,"
                  />
                </td>
                <td>
                  <div style="font-weight: 600">
                    SCHEDULE AND SEND YOUR EMAIL
                  </div>
                  <p>
                    Select your desired sending options, including the date and
                    time for delivery. Consider your target audience's time
                    zones and optimal engagement times for maximum impact.
                  </p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <footer style="padding: 20">
        <p>
          <img
            width="30"
            src="data:image/png;base64,"
          />
        </p>
        <p>© Kmail 2023. All rights reserved</p>
      </footer>
    </div>
  </body>
</html>