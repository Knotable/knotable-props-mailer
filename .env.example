# Supabase client keys (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key

# Supabase service credentials (server-side only)
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_JWT_SECRET=jwt-secret

# Amazon SES SMTP credentials
AWS_SES_SMTP_USERNAME=ses-username
AWS_SES_SMTP_PASSWORD=ses-password
AWS_SES_SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
AWS_SES_SMTP_PORT=587

# Application base URL used by app-generated links and internal callbacks
APP_BASE_URL=http://localhost:3000
